# === Required ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
API_SECRET=your-api-secret

# === LLM Proxy ===
LLM_PROXY_PORT=8200
LLM_MODE=max                          # max | apikey
ANTHROPIC_API_KEY=                     # required if LLM_MODE=apikey
CLAUDE_MAX_SESSION_TOKEN=              # required if LLM_MODE=max
CLAUDE_MAX_COOKIES=                    # required if LLM_MODE=max

# === API ===
API_PORT=8300

# === General ===
TZ=America/Sao_Paulo
NODE_ENV=development
LOG_LEVEL=info                         # trace | debug | info | warn | error | fatal

# === Container ===
POLL_INTERVAL=2000
CONTAINER_TIMEOUT=600000
CONTAINER_IMAGE=orcabot-agent:latest

# === Paths ===
DATA_DIR=./data
GROUPS_DIR=./groups
