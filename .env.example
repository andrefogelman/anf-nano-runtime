# =====================================================================
# Orcamentista IA — Environment variables
# =====================================================================
# Cópia para .env (dev local) E configurar todas no Vercel dashboard
# (Production + Preview + Development) antes do primeiro deploy.
# =====================================================================

# --- Supabase (obrigatório) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...                              # public client key (frontend & server)
SUPABASE_SERVICE_KEY=eyJ...                           # service role (apenas backend FastAPI)
SUPABASE_JWT_SECRET=your-jwt-secret                   # validar JWT no FastAPI (Settings → API → JWT Secret)

# --- API auth (legado / Sprint 0) ---
# Bearer token compartilhado usado pelo frontend hoje. Migrar pra JWT-puro no Sprint 1+.
ORCABOT_API_SECRET=generate-with-openssl-rand-hex-32

# --- LLM providers (vision Q&A) ---
# Sprint 1+ usa pelo menos um destes. OpenAI é o default.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...                          # opcional (alternativa Claude Sonnet 4.6)
GOOGLE_API_KEY=                                       # opcional (alternativa Gemini 3 Pro)

# --- CORS (opcional) ---
# Default "*" no Sprint 0. Tighten para domínio real antes da beta pública.
CORS_ORIGINS=*

# --- Frontend (Vite — variáveis VITE_*) ---
# Estas vão no Vercel dashboard como variáveis de build do frontend.
# Frontend lê via import.meta.env.VITE_*.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_ORCABOT_API_URL=                                 # vazio em produção (mesmo domínio Vercel)
VITE_ORCABOT_API_SECRET=                              # mesmo valor de ORCABOT_API_SECRET
